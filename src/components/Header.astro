---
// Import the image from assets
import logoImg from '../assets/images/logo1.svg';
import { headerData } from '../data/navigation';
import logoSvg from '../assets/images/logo1.svg?raw';
const base = import.meta.env.BASE_URL;
---

<header class="flex justify-between items-center py-4 px-6 bg-white shadow-sm">
  <a href={base} class="flex items-center w-32 h-auto text-blue-600">
    <Fragment set:html={logoSvg} />
  </a>

  <nav>
    <ul class="flex gap-6">
      {headerData.links.map(link => (
        <li>
          <a href={link.href} class="hover:text-blue-600">
            {link.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style is:global>
  /* 3. Ensure the injected SVG behaves well */
  header svg {
    width: 100%;
    height: auto;
    max-height: 40px; /* Adjust this to your preferred logo size */
  }
</style>