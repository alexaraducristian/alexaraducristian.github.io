---
import { Image } from 'astro:assets';
import logoImg from '../assets/images/logo1.svg';
import { headerData } from '../data/navigation';

const { pathname } = Astro.url;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header class="bg-white border-b border-slate-100 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between py-6 md:py-8 transition-all">
    
    <a href={import.meta.env.BASE_URL} class="flex items-center group mb-6 md:mb-0">
      <Image 
        src={logoImg} 
        alt="AlexaVolt Logo" 
        class="h-20 md:h-28 w-auto transition-transform duration-300 group-hover:scale-105"
        inferSize={true}
      />
    </a>

    <nav class="w-full md:w-auto overflow-hidden">
      <div class="overflow-x-auto no-scrollbar scroll-smooth">
        <ul class="flex flex-nowrap items-center gap-2 md:gap-4 py-2">
          {headerData.links.map((link) => {
            const normalizedPath = pathname.replace(/\/$/, "");
            const normalizedHref = link.href.replace(/\/$/, "");
            const isActive = normalizedPath === normalizedHref || 
                             (link.href === import.meta.env.BASE_URL && (normalizedPath === "" || normalizedPath === base));
            
            return (
              <li class="flex-shrink-0">
                <a 
                  href={link.href} 
                  class:list={[
                    "transition-all duration-300 px-5 py-3 rounded-2xl text-lg md:text-xl font-black uppercase tracking-tight flex items-center gap-2 whitespace-nowrap",
                    isActive 
                      ? "bg-blue-600 text-white shadow-lg scale-105" 
                      : "text-slate-700 hover:text-blue-600 hover:bg-slate-100"
                  ]}
                >
                  {link.text}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </nav>
  </div>
</header>

<style>
  /* Mascăm bara de scroll dar păstrăm funcționalitatea de glisare */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none; /* IE și Edge */
    scrollbar-width: none; /* Firefox */
  }
</style>