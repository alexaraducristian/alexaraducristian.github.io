---
import { Image } from 'astro:assets';
import logoImg from '../assets/images/logo1.svg';
import { headerData } from '../data/navigation';

const { pathname } = Astro.url;
---

<header class="p-4 bg-white shadow-md flex justify-between items-center sticky top-0 z-50">
  <a href={import.meta.env.BASE_URL} class="flex-shrink-0">
    <Image 
        src={logoImg} 
        alt="AlexaVolt Logo" 
        class="h-24 md:h-32 w-auto transition-transform duration-300 group-hover:scale-105"
        inferSize={true}
      />
  </a>
  
<nav class="w-full md:w-auto">
  <div class="overflow-x-auto no-scrollbar scroll-smooth">
    <ul class="flex flex-nowrap items-center gap-2 md:gap-4 py-2">
      {headerData.links.map((link) => {
        const normalizedPath = pathname.replace(/\/$/, "");
        const normalizedHref = link.href.replace(/\/$/, "");
        const isActive = normalizedPath === normalizedHref || (link.href === import.meta.env.BASE_URL && (normalizedPath === "" || normalizedPath === "/playground2"));
        
        return (
          <li>
            <a 
              href={link.href} 
              class:list={[
                "transition-all duration-200 px-4 py-2 rounded-xl text-sm md:text-base flex items-center gap-2",
                isActive 
                  ? "bg-blue-600 text-white font-bold shadow-md" 
                  : "text-slate-600 hover:text-blue-600 hover:bg-blue-50"
              ]}
            >
              {link.text}
            </a>
          </li>
        );
      })}
</ul>
  </div>
</nav>
</header>