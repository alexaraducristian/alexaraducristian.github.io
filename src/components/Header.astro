---
import { Image } from 'astro:assets';
import logoImg from '../assets/images/logo1.svg';
import { headerData } from '../data/navigation';

const { pathname } = Astro.url;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header class="bg-white border-b border-slate-100 sticky top-0 z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 md:px-6 flex flex-col md:flex-row items-center justify-between py-4 md:py-6 gap-6 md:gap-0">
    
    <a href={import.meta.env.BASE_URL} class="flex-shrink-0 transition-transform active:scale-95">
      <Image 
        src={logoImg} 
        alt="AlexaVolt Logo" 
        class="h-20 md:h-28 w-auto"
        inferSize={true}
      />
    </a>
    
    <nav class="w-full md:w-auto overflow-hidden">
      <div class="overflow-x-auto no-scrollbar scroll-smooth px-2">
        <ul class="flex flex-nowrap md:flex-wrap items-center justify-center md:justify-end gap-3 md:gap-4">
          {headerData.links.map((link) => {
            const normalizedPath = pathname.replace(/\/$/, "");
            const normalizedHref = link.href.replace(/\/$/, "");
            const isActive = normalizedPath === normalizedHref || 
                             (link.href === import.meta.env.BASE_URL && (normalizedPath === "" || normalizedPath === base));
            
            return (
              <li class="flex-shrink-0 py-1">
                <a 
                  href={link.href} 
                  class:list={[
                    "transition-all duration-300 px-5 py-3 rounded-2xl text-base md:text-lg font-black uppercase tracking-tight flex items-center gap-2 whitespace-nowrap",
                    isActive 
                      ? "bg-blue-600 text-white shadow-lg shadow-blue-200 scale-105" 
                      : "text-slate-700 hover:bg-slate-100 hover:text-blue-600 border border-transparent"
                  ]}
                >
                  <span class="text-xl">{link.text.split(' ')[0]}</span>
                  <span>{link.text.split(' ').slice(1).join(' ')}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </nav>
  </div>
</header>

<style>
  /* Ascunde bara de scroll inestetică pe mobil */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>