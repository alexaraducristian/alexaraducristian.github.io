---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { Image } from 'astro:assets';

// Importuri imagini
import tablouSchneider from '../assets/images/tablou-electric.jpg';
import invertorApp from '../assets/images/invertor-app.jpg';
import tablouNoark from '../assets/images/portofoliu-tablou-electric-2.jpeg';
import sistemHuawei from '../assets/images/portofoliu-tablou-electric-5-plus-invertor.jpeg';
import tablouDetaliu from '../assets/images/portofoliu-tablou-electric-4.jpeg';
import presetupeImg from '../assets/images/portofoliu-tablou-electric-3.jpeg';
import foto1 from '../assets/images/portofoliu-fotovoltaice-1.jpg';
import foto2 from '../assets/images/portofoliu-fotovoltaice-2.jpg';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Organizare Proiecte pe Categorii
const proiecteFotovoltaice = [
  { src: foto1, alt: "Sistem rezidențial", descriere: "Sistem rezidențial" },
  { src: foto2, alt: "Sistem rezidențial", descriere: "Sistem rezidențial" },
  { src: invertorApp, alt: "Monitorizare Huawei", descriere: "Monitorizare Smart Energy" },
  { src: sistemHuawei, alt: "Hibrid Huawei", descriere: "Centrală Huawei" }
];

const proiecteElectrice = [
  { src: tablouSchneider, alt: "Modernizare Schneider", descriere: "Tablou Sigurante Schneider" },
  { src: tablouNoark, alt: "Monitorizare Noark", descriere: "Sistem Noark" },
  { src: tablouDetaliu, alt: "Detalii Executie", descriere: "Management Cablaj Premium" },
  { src: presetupeImg, alt: "Etanșeitate IP65", descriere: "Protecție IP65" }
];
---

<Layout title="Proiecte Realizate | AlexaVolt Portofoliu" description="Portofoliu AlexaVolt: tablouri electrice Schneider, sisteme fotovoltaice Huawei și instalații realizate profesional în zona Iași.">
  <Header />

  <main class="max-w-7xl mx-auto px-6 py-12 font-sans text-slate-800">

    <Breadcrumb pagina="Portofoliu" />
    
    <section class="mb-20 text-center">
      <h1 class="text-4xl md:text-6xl font-black text-slate-900 mb-6 uppercase tracking-tighter">
        Proiecte <span class="text-blue-600">Realizate</span>
      </h1>
      <p class="text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed font-medium">
        Echipa noastră pune accent pe siguranță, eficiență și o execuție tehnică ireproșabilă.
      </p>
    </section>

    <div class="space-y-32">
      
      <section id="panouri-fotovoltaice">
        <h2 class="text-3xl md:text-5xl font-black text-slate-900 mb-12 border-l-[12px] border-emerald-500 pl-6 uppercase tracking-tight">
          ☀️ Sisteme Fotovoltaice
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          {proiecteFotovoltaice.map((item) => (
            <div class="group relative overflow-hidden rounded-[2.5rem] bg-slate-100 shadow-2xl transition-all duration-500 hover:-translate-y-3">
              <Image 
                src={item.src} 
                alt={item.alt}
                class="w-full h-[450px] object-cover transition-transform duration-700 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-emerald-900/90 via-emerald-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 flex flex-col justify-end p-10">
                <p class="text-white font-black text-2xl uppercase tracking-widest translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                  {item.descriere}
                </p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section id="tablouri-electrice">
        <h2 class="text-3xl md:text-5xl font-black text-slate-900 mb-12 border-l-[12px] border-blue-600 pl-6 uppercase tracking-tight">
          ⚡ Tablouri & Instalații
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          {proiecteElectrice.map((item) => (
            <div class="group relative overflow-hidden rounded-[2.5rem] bg-slate-100 shadow-2xl transition-all duration-500 hover:-translate-y-3">
              <Image 
                src={item.src} 
                alt={item.alt}
                class="w-full h-[450px] object-cover transition-transform duration-700 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-blue-900/90 via-blue-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 flex flex-col justify-end p-10">
                <p class="text-white font-black text-2xl uppercase tracking-widest translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                  {item.descriere}
                </p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="bg-slate-900 text-white rounded-[3rem] p-10 md:p-20 shadow-3xl">
        <h2 class="text-3xl md:text-4xl font-black mb-12 text-center uppercase tracking-widest">
          Standarde de Execuție <span class="text-blue-400">AlexaVolt</span>
        </h2>
        <div class="grid md:grid-cols-3 gap-12 text-center">
            <a href={`${base}/articole/cum-sa-alegi-un-tablou-electric/`} class="space-y-4 group hover:scale-105 transition-transform">
                <div class="text-5xl">🛡️</div>
                <h4 class="text-2xl font-bold text-blue-400 group-hover:text-white transition-colors">IP65 / IP67</h4>
                <p class="text-slate-400 font-medium">Etanșeitate absolută pentru toate montajele exterioare.</p>
                <p class="text-blue-400 text-sm opacity-0 group-hover:opacity-100 transition-opacity">Află mai multe →</p>
            </a>
            <a href={`${base}/articole/sertizare-terminale-greseli/`} class="space-y-4 group hover:scale-105 transition-transform">
                <div class="text-5xl">⚙️</div>
                <h4 class="text-2xl font-bold text-blue-400 group-hover:text-white transition-colors">Sertizare Pro</h4>
                <p class="text-slate-400 font-medium">Terminalele sunt sertizate mecanic pentru a elimina riscul contactelor imperfecte.</p>
                <p class="text-blue-400 text-sm opacity-0 group-hover:opacity-100 transition-opacity">Află mai multe →</p>
            </a>
            <a href={`${base}/articole/protectie-dc-fotovoltaice/`} class="space-y-4 group hover:scale-105 transition-transform">
                <div class="text-5xl">📊</div>
                <h4 class="text-2xl font-bold text-blue-400 group-hover:text-white transition-colors">Management DC/AC</h4>
                <p class="text-slate-400 font-medium">Separare fizică strictă între circuitele de curent continuu și alternativ.</p>
                <p class="text-blue-400 text-sm opacity-0 group-hover:opacity-100 transition-opacity">Află mai multe →</p>
            </a>
        </div>
      </section>

    </div>

    <section class="mt-32 text-center pb-20">
      <a href={`${base}/contact/`} class="inline-block bg-blue-600 text-white px-12 py-6 rounded-2xl text-2xl font-black uppercase tracking-tighter hover:bg-blue-700 hover:scale-105 transition-all shadow-2xl shadow-blue-200">
        Vrei un sistem similar? Contactează-ne!
      </a>
    </section>
  </main>
</Layout>