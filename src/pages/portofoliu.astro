---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import { Image } from 'astro:assets';

// Importuri imagini - Verifică extensiile (.jpg vs .jpeg vs .bmp)
import tablouSchneider from '../assets/images/tablou-electric.jpg';
import invertorApp from '../assets/images/invertor-app.jpg';
import tablouNoark from '../assets/images/portofoliu-tablou-electric-2.jpeg';
import sistemHuawei from '../assets/images/portofoliu-tablou-electric-5-plus-invertor.jpeg';
import tablouDetaliu from '../assets/images/portofoliu-tablou-electric-4.jpeg';
import presetupeImg from '../assets/images/portofoliu-tablou-electric-3.jpeg';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Proiecte Realizate | AlexaVolt Portofoliu">
  <Header />

  <main class="max-w-5xl mx-auto px-6 py-12 font-sans text-slate-800">
    <section class="mb-16 text-center">
      <h1 class="text-4xl font-extrabold text-slate-900 mb-6 italic">Proiecte Realizate</h1>
      <p class="text-lg text-slate-600 max-w-3xl mx-auto leading-relaxed">
        Echipa noastră pune accent pe siguranță, eficiență și o execuție tehnică ireproșabilă. Mai jos puteți vizualiza o selecție a lucrărilor noastre recente.
      </p>
    </section>

    <div class="space-y-24">
      
      <section class="grid lg:grid-cols-2 gap-12 items-start">
        <div class="order-2 lg:order-1">
          <h2 class="text-2xl font-bold text-blue-700 mb-4">⚡ 1. Modernizare Tablou Electric Rezidențial</h2>
          <p class="mb-4"><strong>Locație:</strong> Iași</p>
          <p class="text-slate-600 mb-6 italic">Înlocuirea unui tablou vechi cu siguranțe fuzibile cu o soluție modernă Schneider Electric.</p>
          <ul class="space-y-2 text-sm border-l-4 border-blue-100 pl-4">
            <li>• Echipare premium <strong>Acti9/Resi9</strong>.</li>
            <li>• Protecții diferențiale (RCBO) pentru baie și bucătărie.</li>
            <li>• Etichetare clară și management riguros al cablurilor.</li>
          </ul>
        </div>
        <div class="order-1 lg:order-2 rounded-2xl overflow-hidden shadow-xl border border-slate-200">
          <Image src={tablouSchneider} alt="Tablou Schneider" inferSize={true} class="w-full h-auto" />
        </div>
      </section>

      <section class="grid lg:grid-cols-2 gap-12 items-center bg-slate-50 p-8 rounded-[2rem]">
        <div class="rounded-2xl overflow-hidden shadow-xl border border-slate-200">
          <Image src={invertorApp} alt="Monitorizare Fotovoltaice" inferSize={true} class="w-full h-auto" />
        </div>
        <div>
          <h2 class="text-2xl font-bold text-emerald-700 mb-4">☀️ 2. Sistem Fotovoltaic Hibrid 5.5kW</h2>
          <p class="text-slate-600 mb-6">Instalare "la cheie" pentru maximizarea autoconsumului și backup energetic.</p>
          
          <div class="overflow-x-auto mb-6">
            <table class="w-full text-sm text-left border-collapse bg-white rounded-lg overflow-hidden">
              <thead class="bg-emerald-600 text-white">
                <tr>
                  <th class="px-4 py-2 italic font-medium">Parametru (Smart Meter)</th>
                  <th class="px-4 py-2 italic font-medium">Valoare</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr><td class="px-4 py-2">Putere PV Instantanee</td><td class="px-4 py-2 font-bold">~633W</td></tr>
                <tr><td class="px-4 py-2">Producție Zilnică</td><td class="px-4 py-2 font-bold">9.6kWh</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <div class="grid md:grid-cols-2 gap-12">
        <div class="space-y-6">
          <div class="rounded-xl overflow-hidden shadow-lg aspect-square lg:aspect-video">
            <Image src={tablouNoark} alt="Tablou Noark Schrack" inferSize={true} class="w-full h-full object-cover" />
          </div>
          <h3 class="text-xl font-bold">⚡ 3. Monitorizare Noark & Schrack</h3>
          <p class="text-sm text-slate-600">Sisteme trifazate cu Smart Power Sensor pentru controlul precis al exportului în rețea.</p>
        </div>

        <div class="space-y-6">
          <div class="rounded-xl overflow-hidden shadow-lg aspect-square lg:aspect-video">
            <Image src={sistemHuawei} alt="Invertor Huawei" inferSize={true} class="w-full h-full object-cover" />
          </div>
          <h3 class="text-xl font-bold">☀️ 4. Centrală Huawei FusionSolar</h3>
          <p class="text-sm text-slate-600">Configurare hibridă Huawei cu tablouri de protecție DC/AC separate pentru siguranță maximă.</p>
        </div>
      </div>

      <section class="pt-16 border-t border-slate-100">
        <h2 class="text-3xl font-bold mb-10 text-center italic">🛠️ 5. Detalii de Execuție și Management Cablaj</h2>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="space-y-4">
             <Image src={tablouDetaliu} alt="Vedere interioara" inferSize={true} class="rounded-2xl shadow-md" />
             <p class="text-xs italic text-center text-slate-500">Conexiuni sigure prin reglete de distribuție.</p>
          </div>
          <div class="space-y-4">
             <Image src={presetupeImg} alt="Presetupe IP65" inferSize={true} class="rounded-2xl shadow-md" />
             <p class="text-xs italic text-center text-slate-500">Intrări etanșe (IP65) și protecție mecanică.</p>
          </div>
        </div>
        
        <div class="mt-12 bg-blue-50 p-8 rounded-2xl">
            <div class="grid md:grid-cols-3 gap-6 text-center">
                <div><h4 class="font-bold text-blue-800">IP65</h4><p class="text-xs">Etanșeitate garantată</p></div>
                <div><h4 class="font-bold text-blue-800">Terminalele Sertizate</h4><p class="text-xs">Fără contacte imperfecte</p></div>
                <div><h4 class="font-bold text-blue-800">Management DC/AC</h4><p class="text-xs">Circuite separate clar</p></div>
            </div>
        </div>
      </section>
    </div>

    <section class="mt-24 text-center">
      <a href={`${base}/contact`} class="inline-block bg-blue-600 text-white px-10 py-4 rounded-full text-lg font-bold hover:bg-blue-700 transition-all shadow-xl">
        Vrei un sistem similar? Contactează-ne!
      </a>
    </section>
  </main>
</Layout>