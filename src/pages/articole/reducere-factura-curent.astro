---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Cum să reduci factura de curent fără investiții mari | AlexaVolt" description="Sfaturi practice: tarif bi-orar, programare electrocasnice, eliminare standby. Economii de 15-30% fără nicio investiție.">
  <Header />

  <main class="max-w-4xl mx-auto px-6 py-12 font-sans text-slate-800">

    <Breadcrumb pagina="Reducere factură curent" parent="📚 Ghid Practic" parentHref={`${base}/articole/`} />

    <article>
      <header class="mb-12 border-b border-slate-100 pb-10">
        <h1 class="text-3xl md:text-5xl font-extrabold text-slate-900 mb-4 leading-tight">
          Cum să reduci <span class="text-emerald-600">factura de curent</span> fără investiții mari
        </h1>
        <p class="text-lg text-slate-600 leading-relaxed">
          Economii de 15-30% sunt posibile doar cu schimbări de comportament și câteva setări. Fără panouri solare, fără renovare — doar decizii inteligente.
        </p>
      </header>

      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-4 flex items-center gap-2">
          <span>⏰</span> Tariful bi-orar — cel mai simplu câștig
        </h2>
        <p class="text-slate-600 mb-4 leading-relaxed">
          Dacă ai contor smart (electronic), poți solicita furnizorului trecerea pe tarif bi-orar. Diferența e semnificativă:
        </p>
        <div class="overflow-x-auto mb-4">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="bg-slate-100">
                <th class="p-3 text-left font-bold border border-slate-200">Interval</th>
                <th class="p-3 text-left font-bold border border-slate-200">Ore</th>
                <th class="p-3 text-left font-bold border border-slate-200">Preț orientativ</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="p-3 border border-slate-200 font-semibold text-red-700">Zi (vârf)</td>
                <td class="p-3 border border-slate-200">07:00 – 22:00</td>
                <td class="p-3 border border-slate-200">~1.3 lei/kWh</td>
              </tr>
              <tr class="bg-blue-50">
                <td class="p-3 border border-slate-200 font-semibold text-blue-700">Noapte (gol)</td>
                <td class="p-3 border border-slate-200">22:00 – 07:00</td>
                <td class="p-3 border border-slate-200">~0.65 lei/kWh (50% reducere)</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="bg-blue-50 p-4 rounded-xl border border-blue-100">
          <p class="text-sm text-emerald-800"><strong>💡 Sfat:</strong> Merită dacă poți muta minim 30% din consum pe noapte (mașina de spălat, uscător, boiler, încărcare EV).</p>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6 flex items-center gap-2">
          <span>🌙</span> Ce poți programa noaptea
        </h2>
        <div class="grid md:grid-cols-2 gap-4">
          <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
            <p class="font-bold text-slate-800">Mașina de spălat</p>
            <p class="text-sm text-slate-600">Timer la 22:00 — economie ~0.5 lei/spălare</p>
          </div>
          <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
            <p class="font-bold text-slate-800">Mașina de spălat vase</p>
            <p class="text-sm text-slate-600">Programare nocturnă — economie ~0.3 lei/ciclu</p>
          </div>
          <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
            <p class="font-bold text-slate-800">Boiler electric</p>
            <p class="text-sm text-slate-600">Încălzire nocturnă, termostat la 55°C — economie ~30 lei/lună</p>
          </div>
          <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
            <p class="font-bold text-slate-800">Încărcare mașină electrică</p>
            <p class="text-sm text-slate-600">Programare 22:00-06:00 — economie ~100-150 lei/lună</p>
          </div>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-4 flex items-center gap-2">
          <span>🔌</span> Consumul standby — hoțul invizibil
        </h2>
        <p class="text-slate-600 mb-4 leading-relaxed">
          Aparatele în standby consumă 5-25W fiecare, non-stop. Pe un an, asta înseamnă <strong>100-300 lei aruncați pe geam</strong>.
        </p>
        <div class="overflow-x-auto mb-4">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="bg-slate-100">
                <th class="p-3 text-left font-bold border border-slate-200">Aparat</th>
                <th class="p-3 text-left font-bold border border-slate-200">Standby</th>
                <th class="p-3 text-left font-bold border border-slate-200">Cost anual</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="p-3 border border-slate-200">TV + soundbar + media box</td>
                <td class="p-3 border border-slate-200">15-25W</td>
                <td class="p-3 border border-slate-200">~100-180 lei</td>
              </tr>
              <tr class="bg-slate-50">
                <td class="p-3 border border-slate-200">Consolă de jocuri</td>
                <td class="p-3 border border-slate-200">10-15W</td>
                <td class="p-3 border border-slate-200">~70-100 lei</td>
              </tr>
              <tr>
                <td class="p-3 border border-slate-200">PC desktop + monitor</td>
                <td class="p-3 border border-slate-200">5-10W</td>
                <td class="p-3 border border-slate-200">~35-70 lei</td>
              </tr>
              <tr class="bg-slate-50">
                <td class="p-3 border border-slate-200">Încărcătoare lăsate în priză</td>
                <td class="p-3 border border-slate-200">2-5W (fiecare)</td>
                <td class="p-3 border border-slate-200">~15-35 lei (fiecare)</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="bg-blue-50 p-4 rounded-xl border border-blue-100">
          <p class="text-sm text-blue-800"><strong>Soluție:</strong> Priză cu întrerupător (5 lei) sau smart plug cu programare (40-60 lei) — oprești standby-ul grupat.</p>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-4 flex items-center gap-2">
          <span>💡</span> Iluminat — economii rapide
        </h2>
        <ul class="space-y-3 text-slate-600">
          <li class="flex items-start gap-3"><span class="text-emerald-600 font-bold">•</span> Un bec LED de 10W = lumina unui bec incandescent de 75W → <strong>economie 85%</strong></li>
          <li class="flex items-start gap-3"><span class="text-emerald-600 font-bold">•</span> Durata de viață: LED = 25.000h vs incandescent = 1.000h</li>
          <li class="flex items-start gap-3"><span class="text-emerald-600 font-bold">•</span> Cost anual iluminat (5h/zi): LED 10W = ~24 lei vs incandescent 75W = ~180 lei</li>
          <li class="flex items-start gap-3"><span class="text-emerald-600 font-bold">•</span> Senzori de mișcare în hol/baie — economie 40-60% pe iluminat</li>
        </ul>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-4 flex items-center gap-2">
          <span>📱</span> Smart plugs pentru monitorizare
        </h2>
        <p class="text-slate-600 mb-4 leading-relaxed">
          Un smart plug de 40-60 lei (Shelly, Sonoff, TP-Link) îți arată exact cât consumă fiecare aparat. Identifici „consumatorii ascunși" și decizi ce merită oprit.
        </p>
        <div class="bg-blue-50 p-5 rounded-2xl border border-blue-100">
          <p class="font-bold text-emerald-800 mb-2">📊 Exemplu real de economie lunară:</p>
          <ul class="space-y-1 text-sm text-slate-700">
            <li>Tarif bi-orar (mașină spălat + boiler noaptea): <strong>-50 lei</strong></li>
            <li>Eliminare standby TV + consolă: <strong>-15 lei</strong></li>
            <li>LED în loc de halogen (10 spoturi): <strong>-30 lei</strong></li>
            <li>Total economie lunară: <strong>~95 lei (fără investiție majoră)</strong></li>
          </ul>
        </div>
      </section>

      <section class="mb-12 bg-slate-50 p-6 rounded-2xl border border-slate-100">
        <h2 class="text-xl font-bold text-slate-900 mb-4">📖 Articole similare</h2>
        <ul class="space-y-2">
          <li><a href={`${base}/articole/contor-smart-cum-citesti/`} class="text-blue-600 font-semibold hover:text-blue-800 transition-colors">Contor smart — cum citești datele →</a></li>
          <li><a href={`${base}/articole/cum-sa-calculezi-panouri-fotovoltaice/`} class="text-blue-600 font-semibold hover:text-blue-800 transition-colors">Cum calculezi numărul de panouri necesare →</a></li>
          <li><a href={`${base}/articole/iluminat-led-ghid-alegere/`} class="text-blue-600 font-semibold hover:text-blue-800 transition-colors">Ghid alegere iluminat LED →</a></li>
        </ul>
      </section>

      <section class="text-center border-t border-slate-100 pt-10">
        <h2 class="text-2xl font-bold mb-4 text-slate-900">Vrei să optimizezi consumul profesional?</h2>
        <p class="text-slate-600 mb-8 max-w-2xl mx-auto">
          AlexaVolt face audit energetic și implementează soluții concrete: circuite dedicate, smart plugs, programări automate.
        </p>
        <a href={`${base}/contact/`} class="inline-block bg-blue-600 text-white px-10 py-4 rounded-full text-lg font-bold hover:bg-blue-700 transition-all shadow-xl hover:-translate-y-1">
          Solicită audit energetic
        </a>
      </section>
    </article>
  </main>
</Layout>
