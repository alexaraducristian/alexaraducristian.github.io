---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Panouri fotovoltaice cu baterie vs fără — merită stocarea? | AlexaVolt" description="Panouri fotovoltaice cu baterie vs fără: calcul ROI, când merită stocarea și cât costă un sistem cu baterie LiFePO4 în România.">
  <Header />

  <main class="max-w-4xl mx-auto px-6 py-12 font-sans text-slate-800">

    <Breadcrumb pagina="Cu baterie vs. fără baterie" parent="📚 Ghid Practic" parentHref={`${base}/articole/`} />

    <article>
      <header class="mb-12 border-b border-slate-100 pb-10">
        <h1 class="text-3xl md:text-5xl font-extrabold text-slate-900 mb-4 leading-tight">
          Panouri fotovoltaice <span class="text-emerald-600">cu baterie</span> vs
          <span class="text-blue-600">fără</span> — merită stocarea?
        </h1>
        <p class="text-lg text-slate-600 leading-relaxed">
          Analiză completă: costuri, avantaje, dezavantaje și când
          are sens financiar să adaugi o baterie de stocare.
        </p>
      </header>

      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6 flex items-center gap-2">
          <span>⚖️</span> Comparație directă
        </h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-slate-100 text-slate-800">
                <th class="p-3 text-left rounded-tl-lg">Aspect</th>
                <th class="p-3 text-left text-emerald-700">Cu baterie</th>
                <th class="p-3 text-left text-blue-700 rounded-tr-lg">Fără baterie</th>
              </tr>
            </thead>
            <tbody class="text-slate-600">
              <tr class="border-t border-slate-100">
                <td class="p-3 font-semibold">Cost suplimentar</td>
                <td class="p-3">+15,000-25,000 lei (10 kWh)</td>
                <td class="p-3">—</td>
              </tr>
              <tr class="border-t border-slate-100">
                <td class="p-3 font-semibold">Autoconsum</td>
                <td class="p-3">80-95%</td>
                <td class="p-3">50-70%</td>
              </tr>
              <tr class="border-t border-slate-100">
                <td class="p-3 font-semibold">Independență energetică</td>
                <td class="p-3">Ridicată</td>
                <td class="p-3">Parțială (doar ziua)</td>
              </tr>
              <tr class="border-t border-slate-100">
                <td class="p-3 font-semibold">Funcționare la pană de curent</td>
                <td class="p-3">✅ Da (cu invertor hibrid)</td>
                <td class="p-3">❌ Nu</td>
              </tr>
              <tr class="border-t border-slate-100">
                <td class="p-3 font-semibold">Amortizare baterie</td>
                <td class="p-3">7-10 ani</td>
                <td class="p-3">—</td>
              </tr>
              <tr class="border-t border-slate-100">
                <td class="p-3 font-semibold">Durată de viață baterie</td>
                <td class="p-3">10-15 ani (6000+ cicluri)</td>
                <td class="p-3">—</td>
              </tr>
              <tr class="border-t border-slate-100">
                <td class="p-3 font-semibold">Complexitate sistem</td>
                <td class="p-3">Mai ridicată</td>
                <td class="p-3">Simplă</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6 flex items-center gap-2">
          <span>💰</span> Calcul ROI pentru baterie (10 kWh)
        </h2>
        <div class="bg-emerald-50 p-6 rounded-2xl border border-emerald-100">
          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <h3 class="font-bold text-emerald-800 mb-3">Investiție</h3>
              <ul class="space-y-2 text-sm text-slate-700">
                <li><strong>Baterie 10 kWh (Huawei LUNA2000):</strong> ~18,000 lei</li>
                <li><strong>Instalare + accesorii:</strong> ~2,000 lei</li>
                <li><strong>Total suplimentar:</strong> ~20,000 lei</li>
              </ul>
            </div>
            <div>
              <h3 class="font-bold text-emerald-800 mb-3">Economie anuală suplimentară</h3>
              <ul class="space-y-2 text-sm text-slate-700">
                <li><strong>Energie stocată/zi:</strong> ~8 kWh</li>
                <li><strong>Economie/zi:</strong> ~10.4 lei</li>
                <li><strong>Economie/an:</strong> ~2,500-3,000 lei</li>
                <li class="text-emerald-700 font-bold">→ Amortizare: ~7-8 ani</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6 flex items-center gap-2">
          <span>✅</span> Când MERITĂ bateria
        </h2>
        <div class="space-y-4">
          <div class="bg-emerald-50 p-5 rounded-2xl border border-emerald-100">
            <h3 class="font-bold text-emerald-800 mb-2">Pane de curent frecvente</h3>
            <p class="text-sm text-slate-600">Zone rurale sau suburbane cu rețea instabilă. Bateria + invertorul hibrid asigură backup automat — casa funcționează și fără rețea.</p>
          </div>
          <div class="bg-emerald-50 p-5 rounded-2xl border border-emerald-100">
            <h3 class="font-bold text-emerald-800 mb-2">Consum mare seara/noaptea</h3>
            <p class="text-sm text-slate-600">Dacă 60%+ din consum e după apusul soarelui (AC noaptea, mașină de spălat seara, EV charging nocturn), bateria transferă producția din zi pentru consum nocturn.</p>
          </div>
          <div class="bg-emerald-50 p-5 rounded-2xl border border-emerald-100">
            <h3 class="font-bold text-emerald-800 mb-2">Dorință de independență totală</h3>
            <p class="text-sm text-slate-600">Vrei să fii cât mai puțin dependent de furnizor și de fluctuațiile de preț. Cu baterie suficientă, poți acoperi 90%+ din consum.</p>
          </div>
          <div class="bg-emerald-50 p-5 rounded-2xl border border-emerald-100">
            <h3 class="font-bold text-emerald-800 mb-2">Subvenție disponibilă (Casa Verde baterii)</h3>
            <p class="text-sm text-slate-600">Dacă ești deja prosumator și poți accesa finanțare pentru stocare, ROI-ul se scurtează semnificativ.</p>
          </div>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6 flex items-center gap-2">
          <span>❌</span> Când NU merită (deocamdată)
        </h2>
        <div class="space-y-4">
          <div class="bg-red-50 p-5 rounded-2xl border border-red-100">
            <h3 class="font-bold text-red-800 mb-2">Buget limitat</h3>
            <p class="text-sm text-slate-600">Dacă bugetul e strâns, investește mai degrabă în panouri suplimentare sau un invertor hibrid (pregătit pentru baterie ulterior) decât în baterie acum.</p>
          </div>
          <div class="bg-red-50 p-5 rounded-2xl border border-red-100">
            <h3 class="font-bold text-red-800 mb-2">Consum majoritar diurn</h3>
            <p class="text-sm text-slate-600">Lucrezi de acasă, consumi mult ziua → autoconsumul e deja 70%+ fără baterie. Beneficiul suplimentar al bateriei e mic.</p>
          </div>
          <div class="bg-red-50 p-5 rounded-2xl border border-red-100">
            <h3 class="font-bold text-red-800 mb-2">Rețea stabilă + compensare netă</h3>
            <p class="text-sm text-slate-600">Dacă furnizorul compensează corect exportul și nu ai pene de curent, rețeaua funcționează ca o „baterie virtuală" gratuită.</p>
          </div>
        </div>
      </section>

      <section class="mb-12 bg-blue-50 p-8 rounded-3xl border border-blue-100">
        <h2 class="text-2xl font-bold text-blue-800 mb-4">💡 Strategia optimă</h2>
        <p class="text-slate-700 mb-4">
          Recomandarea noastră pentru majoritatea clienților:
        </p>
        <ol class="space-y-3 text-slate-700">
          <li><strong>1.</strong> Instalează panouri + invertor <strong>hibrid</strong> (pregătit pentru baterie)</li>
          <li><strong>2.</strong> Folosește sistemul 6-12 luni și monitorizează autoconsumul real</li>
          <li><strong>3.</strong> Dacă exportezi mult în rețea (>40%), adaugă baterie ulterior</li>
          <li><strong>4.</strong> Sau așteaptă o rundă de subvenții pentru stocare</li>
        </ol>
        <p class="text-sm text-slate-600 mt-4">
          Astfel nu supradimensionezi investiția inițială, dar păstrezi flexibilitatea.
        </p>
      </section>

      <section class="mb-12 bg-slate-50 p-6 rounded-2xl border border-slate-100">
        <h2 class="text-xl font-bold text-slate-900 mb-4">📖 Articole similare</h2>
        <ul class="space-y-2">
          <li><a href={`${base}/articole/amortizare-sistem-fotovoltaic/`} class="text-blue-600 font-semibold hover:text-blue-800 transition-colors">Amortizarea unui sistem fotovoltaic →</a></li>
          <li><a href={`${base}/articole/cum-functioneaza-invertor-hibrid/`} class="text-blue-600 font-semibold hover:text-blue-800 transition-colors">Cum funcționează un invertor hibrid →</a></li>
          <li><a href={`${base}/articole/subventii-fotovoltaice-2026/`} class="text-blue-600 font-semibold hover:text-blue-800 transition-colors">Subvenții fotovoltaice 2026 — ce poți obține →</a></li>
        </ul>
      </section>

      <section class="text-center border-t border-slate-100 pt-10">
        <h2 class="text-2xl font-bold mb-4 text-slate-900">Vrei să afli dacă bateria face sens pentru tine?</h2>
        <p class="text-slate-600 mb-8 max-w-2xl mx-auto">
          AlexaVolt analizează profilul tău de consum, tarifele și stabilitatea rețelei locale pentru o recomandare informată.
        </p>
        <a href={`${base}/contact/`} class="inline-block bg-blue-600 text-white px-10 py-4 rounded-full text-lg font-bold hover:bg-blue-700 transition-all shadow-xl hover:-translate-y-1">
          Solicită simulare
        </a>
      </section>
    </article>
  </main>
</Layout>
