---

<Layout title="Articole & Ghiduri Electrice | AlexaVolt" description="Ghiduri practice despre instalații electrice, tablouri, panouri fotovoltaice și energie verde. Articole scrise de electricieni autorizați ANRE Iași.">
  <Header />

  <main class="max-w-5xl mx-auto px-6 py-12 font-sans text-slate-800">

    <Breadcrumb pagina="Ghid Practic" />

    <section class="mb-12 border-b border-slate-100 pb-10">
      <h1 class="text-3xl md:text-5xl font-extrabold text-slate-900 mb-4 leading-tight">
        📚 Articole & <span class="text-blue-600">Ghiduri Practice</span>
      </h1>
      <p class="text-lg text-slate-600 leading-relaxed">
        Instrucțiuni pas cu pas despre instalații electrice și sisteme fotovoltaice — scrise de specialiști autorizați ANRE Iași.
      </p>
    </section>

    <!-- Category navigation cards -->
    <section class="mb-14">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3">
        {categorii.map((cat) => (
          <a href={`#${cat.slug}`} class="group p-4 rounded-2xl border border-slate-100 bg-white hover:bg-blue-50 hover:border-blue-200 transition-all text-center shadow-sm hover:shadow-md">
            <div class="text-2xl mb-2">{cat.titlu.split(' ')[0]}</div>
            <p class="text-xs font-bold text-slate-700 group-hover:text-blue-700 leading-tight">{cat.titlu.replace(/^[^\s]+\s/, '')}</p>
            <p class="text-[10px] text-slate-400 mt-1">{cat.articole.length} articole</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Article sections -->
    {categorii.map((cat) => (
      <section id={cat.slug} class="mb-10 scroll-mt-24">
        <div class="sticky top-[72px] z-10 bg-white/95 backdrop-blur-sm py-3 mb-4 border-b border-slate-100">
          <h2 class="text-xl font-bold text-slate-900">{cat.titlu}</h2>
        </div>
        <ul class="space-y-1">
          {cat.articole.map((art) => (
            <li>
              <a href={art.href} class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-blue-50 transition-colors group">
                <span class="text-blue-400 group-hover:text-blue-600 transition-colors">→</span>
                <span class="text-base text-slate-800 group-hover:text-blue-700 font-medium transition-colors">{art.titlu}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}

  </main>
</Layout>
