      },
      {
        titlu: "Cum se face corect sertizarea terminalelor — greșeli frecvente",
        descriere: "Forță, calibru, verificare vizuală. Conexiuni fiabile și sigure.",
        href: `${base}/articole/sertizare-terminale-greseli/`,
      },
      {
        titlu: "Cabluri NYM vs CYY vs FY — când folosești fiecare tip",
        descriere: "Comparație, aplicații și cerințe normativ I7.",
        href: `${base}/articole/cabluri-nym-cyy-fy/`,
      },
      {
        titlu: "Cum se calculează căderea de tensiune pe traseu lung",
        descriere: "Formula, tabel practic și exemple. Max admis: 3% iluminat, 5% prize.",
        href: `${base}/articole/cadere-tensiune-calcul/`,
      },
      {
        titlu: "Protecția la arc electric (AFDD) — merită în rezidențial?",
        descriere: "Ce este, cum detectează arcul și analiză cost vs beneficiu.",
        href: `${base}/articole/protectie-arc-afdd/`,
      },
    ]
