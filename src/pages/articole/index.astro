        descriere: "Documente, examen, tipuri (A, B, C1, C2) și reînnoire.",
        href: `${base}/articole/obtinere-autorizare-anre/`,
      },
      {
        titlu: "Cum să faci un deviz corect pentru o instalație electrică",
        descriere: "Structură, norme de deviz, marje și prezentare transparentă.",
        href: `${base}/articole/deviz-instalatie-electrica/`,
      },
    ]
