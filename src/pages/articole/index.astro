      },
      {
        titlu: "Cum să reduci factura de curent fără investiții mari",
        descriere: "Tarif bi-orar, programare electrocasnice, eliminare standby. Economii 15-30%.",
        href: `${base}/articole/reducere-factura-curent/`,
      },
      {
        titlu: "Contorul smart: cum să-l citești și ce date îți oferă",
        descriere: "Ghid vizual pentru contoarele Sagemcom/Landis+Gyr din România.",
        href: `${base}/articole/contor-smart-cum-citesti/`,
      },
    ]
  },
  {
    titlu: "📜 Legislație & Conformitate",
    slug: "legislatie-conformitate",
    articole: [
      {
        titlu: "Ce este autorizarea ANRE și de ce contează pentru tine",
        descriere: "Tipuri de autorizare, riscuri fără autorizat, cum verifici.",
