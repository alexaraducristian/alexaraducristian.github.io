    ]
  },
  {
    titlu: "☀️ Panouri Fotovoltaice & Energie Verde",
    slug: "panouri-fotovoltaice",
    articole: [
      {
        titlu: "Cum să calculezi câte panouri fotovoltaice ai nevoie",
