  {
    titlu: "🏠 Smart Home & Iluminat",
    slug: "smart-home-iluminat",
    articole: [
      {
        titlu: "Cum să faci casa smart fără să refaci instalația electrică",
        descriere: "Soluții retrofit: Shelly, Sonoff, smart plugs și protocoale.",
        href: `${base}/articole/smart-home-fara-renovare/`,
      },
      {
        titlu: "Iluminat LED: cum să alegi becurile potrivite pentru fiecare cameră",
        descriere: "Lumeni, temperatură culoare, CRI și recomandări per cameră.",
        href: `${base}/articole/iluminat-led-ghid-alegere/`,
      },
    ]
  },
  {
    titlu: "🔬 Tehnic & Proiectare (Pentru Electricieni)",
    slug: "tehnic-proiectare",
    articole: [
