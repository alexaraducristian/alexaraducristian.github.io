        href: `${base}/articole/cum-functioneaza-un-spd/`,
      },
      {
        titlu: "Semne că tabloul tău electric e depășit și trebuie modernizat",
        descriere: "Checklist vizual cu semnalele de alarmă.",
        href: `${base}/articole/semne-tablou-electric-depasit/`,
      },
      {
        titlu: "Cum se citește schema unui tablou electric",
        descriere: "Ghid pentru înțelegerea etichetelor și circuitelor.",
        href: `${base}/articole/cum-se-citeste-schema-tablou-electric/`,
