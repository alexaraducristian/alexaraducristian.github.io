---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { Image } from 'astro:assets';

import graphImg from '../assets/images/1.png';
import schemaImg from '../assets/images/3.png';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Energie Verde | Panouri Fotovoltaice AlexaVolt" description="Panouri fotovoltaice Iași — economisește mii de lei anual. Simulare gratuită Cool-PVT, montaj autorizat ANRE, amortizare în 4-5 ani.">
  <Header />

  <main class="max-w-5xl mx-auto px-6 py-12 font-sans text-slate-800">

    <Breadcrumb pagina="Energie Verde" />

    <section class="mb-16 border-b border-slate-100 pb-12">
      <h1 class="text-3xl md:text-5xl font-extrabold text-slate-900 mb-6 leading-tight">
        Te-ai întrebat câți bani pierzi în fiecare zi în care nu ai <span class="text-emerald-600">Panouri Fotovoltaice?</span> ☀️
      </h1>
      <p class="text-lg text-slate-500 font-medium mb-4">Electrician autorizat ANRE Iași — montaj profesional panouri solare</p>
      <p class="text-xl text-slate-600 max-w-3xl mx-auto">
        Prețul energiei electrice este într-o continuă fluctuație, dar soarele trimite energie gratis în fiecare zi. Dacă acoperișul tău este gol, <strong class="text-slate-900">pierzi bani în fiecare oră cu lumină.</strong>
      </p>
    </section>

    <div class="grid md:grid-cols-2 gap-12 mb-20">
      <section class="bg-red-50 p-8 rounded-3xl border border-red-100">
        <h2 class="text-2xl font-bold text-red-800 mb-6 flex items-center gap-2">
          📉 Cât te costă INACȚIUNEA?
        </h2>
        <ul class="space-y-4 text-slate-700">
          <li class="flex gap-3">
            <span class="text-red-500 font-bold">•</span>
            <span><strong>Facturi lunare:</strong> Sute de lei care se duc către furnizori, în loc să rămână în bugetul familiei.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-red-500 font-bold">•</span>
            <span><strong>Inflația energetică:</strong> Ești vulnerabil la orice creștere de tarif anunțată pe piață.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-red-500 font-bold">•</span>
            <span><strong>Deprecierea activelor:</strong> O casă fără independență energetică este mai puțin atractivă pe piață.</span>
          </li>
        </ul>
      </section>

      <section class="bg-emerald-50 p-8 rounded-3xl border border-emerald-100">
        <h2 class="text-2xl font-bold text-emerald-800 mb-6 flex items-center gap-2">
          🚗 Încarcă GRATIS mașina!
        </h2>
        <p class="mb-4 text-emerald-900">Sistemul fotovoltaic îți transformă acoperișul în propria "benzinărie":</p>
        <ul class="space-y-4 text-slate-700">
          <li class="flex gap-3">
            <span class="text-emerald-600 font-bold">✓</span>
            <span><strong>Cost per km: 0 RON.</strong> Încarci bateria folosind exclusiv lumina soarelui.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-emerald-600 font-bold">✓</span>
            <span><strong>Independență totală:</strong> Nu mai depinzi de stațiile publice și tarifele lor mari.</span>
          </li>
        </ul>
      </section>
    </div>

    <section class="mb-20">
      <h2 class="text-3xl font-bold mb-8 text-center text-slate-900">🏠 Unde pleacă banii tăi?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="p-6 bg-white border border-slate-200 rounded-2xl shadow-sm">
          <div class="text-3xl mb-3">❄️</div>
          <h4 class="font-bold mb-2">Aer Condiționat</h4>
          <p class="text-sm text-slate-500 italic">Consum: 9 kWh/zi</p>
        </div>
        <div class="p-6 bg-white border border-slate-200 rounded-2xl shadow-sm">
          <div class="text-3xl mb-3">🚿</div>
          <h4 class="font-bold mb-2">Boiler Electric</h4>
          <p class="text-sm text-slate-500 italic">Consum: 4 kWh/zi</p>
        </div>
        <div class="p-6 bg-white border border-slate-200 rounded-2xl shadow-sm">
          <div class="text-3xl mb-3">🧼</div>
          <h4 class="font-bold mb-2">Mașini de Spălat</h4>
          <p class="text-sm text-slate-500 italic">Consum: 2.5 kWh/zi</p>
        </div>
        <div class="p-6 bg-white border border-slate-200 rounded-2xl shadow-sm">
          <div class="text-3xl mb-3">🔌</div>
          <h4 class="font-bold mb-2">Electronice/Standby</h4>
          <p class="text-sm text-slate-500 italic">Consum: 1.5 kWh/zi</p>
        </div>
      </div>
    </section>

    <section class="bg-slate-900 text-white p-8 md:p-12 rounded-[2rem] mb-20 shadow-2xl">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-bold mb-6 flex items-center gap-3">
          <span class="text-blue-400 text-4xl">🎓</span> Expertiză Academică
        </h2>
        <p class="text-slate-300 leading-relaxed mb-6">
          Software-ul de simulare utilizat <span class="text-orange-400 font-bold">(Cool-PVT)</span> este rezultatul unui proces avansat de dezvoltare desfășurat în cadrul <strong class="text-white">Universității Tehnice „Gheorghe Asachi” din Iași</strong>.
        </p>
        <p class="text-slate-400 text-sm italic">
          Algoritmii de calcul au fost validați de profesori cu vastă experiență, garantând o precizie la standarde europene.
        </p>
      </div>
    </section>

    <section class="mb-20 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl font-bold mb-8">📊 Studiu de Caz: Rezidențial</h2>
        <div class="space-y-6">
          <div class="flex justify-between border-b pb-2">
            <span>💰 Investiție Inițială</span>
            <span class="font-mono font-bold">16.827 RON</span>
          </div>
          <div class="flex justify-between border-b pb-2 text-emerald-600">
            <span>⏱️ Amortizare</span>
            <span class="font-bold text-lg">Doar 5 ani</span>
          </div>
          <div class="flex justify-between border-b pb-2">
            <span>🚀 Profit Net (Anul 10)</span>
            <span class="font-bold text-xl text-blue-600">20.978 RON</span>
          </div>
        </div>
        <div class="mt-8 p-4 bg-blue-900 text-white rounded-lg text-sm inline-block">
          Echipamente Tier 1 + Montaj <span class="bg-blue-700 px-2 rounded">Autorizat ANRE</span>
        </div>
      </div>
      
      <div class="rounded-2xl overflow-hidden shadow-2xl border border-slate-200 bg-white p-4">
      <Image src={graphImg} alt="Grafic" width={1200} height={800} />
      <p class="text-center text-xs text-slate-400 mt-4 italic">Imagine 1: Analiza randamentului și a fluxului de numerar</p>
      </div>
    </section>

    <section class="mb-20 bg-slate-50 p-8 rounded-3xl">
      <h3 class="text-2xl font-bold mb-6">🛠️ Detalii Tehnice de Proiectare</h3>
      <div class="grid lg:grid-cols-2 gap-8 items-center">
        <p class="text-slate-600">
          Configurăm șirurile de panouri (strings) pentru a lucra în plaja optimă de tensiune a invertorului. Utilizăm conductori de <strong>6 mmp</strong> pentru pierderi minime.
        </p>
        <div class="rounded-xl overflow-hidden shadow-lg border border-slate-200">
          <Image src={schemaImg} alt="Schema de interconectare strings" class="w-full h-auto" width={1200} height={800} />
        </div>
      </div>
    </section>

    <section class="mb-20 bg-amber-50 border border-amber-200 p-8 rounded-3xl">
      <h2 class="text-2xl font-bold text-amber-900 mb-4 flex items-center gap-2">
        🔒 De ce montaj autorizat ANRE?
      </h2>
      <ul class="space-y-3 text-slate-700">
        <li class="flex gap-3 items-start">
          <span class="text-amber-600 font-bold">✓</span>
          <span><strong>Statut de prosumator:</strong> Obținerea statutului de prosumator și racordarea la rețea necesită obligatoriu un instalator autorizat ANRE.</span>
        </li>
        <li class="flex gap-3 items-start">
          <span class="text-amber-600 font-bold">✓</span>
          <span><strong>Garanție validă:</strong> Garanția panourilor și invertorului se invalidează fără documentație de montaj de la un electrician autorizat.</span>
        </li>
        <li class="flex gap-3 items-start">
          <span class="text-amber-600 font-bold">✓</span>
          <span><strong>Siguranță DC:</strong> Tensiunile de curent continuu de pe acoperiș pot depăși 600V — montajul neautorizat este extrem de periculos.</span>
        </li>
      </ul>
    </section>

    <section class="text-center bg-blue-600 text-white p-12 rounded-[3rem] shadow-2xl">
      <h2 class="text-3xl font-bold mb-6 italic">Gata să oprești pierderile financiare?</h2>
      <a 
        href={`${base}/contact/`} 
        class="inline-block bg-white text-blue-600 px-12 py-4 rounded-full text-xl font-bold hover:bg-slate-100 transition-all shadow-xl hover:-translate-y-1"
      >
        Solicită Simulare Gratuită Acum →
      </a>
      <p class="mt-4 text-sm text-blue-100">✓ Evaluare la domiciliu fără obligații · ✓ Montaj autorizat ANRE</p>
    </section>
  </main>
</Layout>